#
# Copia este archivo a .env.production y completa los valores reales.
# NUNCA subas el archivo .env.production a git.

# ── Base de datos ──────────────────────────────────────────
DB_USER=ucez_user
DB_PASSWORD=CAMBIA_ESTA_CONTRASENA_SEGURA
DB_NAME=ucez_db

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=GENERA_UN_SECRET_MUY_LARGO_Y_ALEATORIO_AQUI
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=GENERA_OTRO_SECRET_MUY_LARGO_Y_ALEATORIO_AQUI
JWT_REFRESH_EXPIRES_IN=7d

# ── URLs ───────────────────────────────────────────────────
FRONTEND_URL=https://ucez.com
NEXT_PUBLIC_API_URL=https://ucez.com/api/v1

# ── Email (SMTP) ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-contrasena-de-aplicacion-gmail
EMAIL_FROM="UCEZ - Cámara de Comercio <noreply@ucez.com>"
